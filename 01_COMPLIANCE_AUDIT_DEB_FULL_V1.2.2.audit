<custom_item>
  type        : CMD_EXEC
  description : "198, SUID SGID revisados, Alta"
  info        : "Lista arquivos com bits SUID ou SGID definidos"
  solution    : "Rever binarios SUID e SGID"
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( find / -xdev \\( -perm -4000 -o -perm -2000 \\) 2>/dev/null | grep -Ev '\"'\"'^(/usr/bin/sudo|/usr/bin/su|/bin/su|/usr/bin/passwd|/usr/bin/chage|/usr/bin/chsh|/usr/bin/chfn|/usr/bin/newgrp|/usr/bin/gpasswd|/usr/sbin/unix_chkpwd|/usr/sbin/pam_timestamp_check|/usr/bin/mount|/usr/bin/umount|/usr/bin/fusermount|/usr/bin/pkexec|/usr/bin/crontab|/usr/bin/ssh-agent|/usr/bin/ksu|/usr/libexec/openssh/ssh-keysign|/usr/bin/ping|/usr/bin/ping6|/usr/bin/traceroute|/usr/bin/traceroute6)$'\"'\"' | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "199, Home ausente, Baixa"
  info        : "Verificar usuários sem diretório home"
  solution    : "Verificar usuários sem diretório home"
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd | while read -r h; do [ -d \"$h\" ] || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "200, Ownership home, Alta"
  info        : "Verificar ownership dos diretórios home"
  solution    : "Ajustar ownership dos diretórios home para o respectivo usuário."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $1,$6}'\"'\"' /etc/passwd | while read -r u h; do [ -d \"$h\" ] && [ \"$(stat -Lc %U \"$h\")\" = \"$u\" ] || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "201, Permissões home, Alta"
  info        : "Verificar permissões dos diretórios home"
  solution    : "Ajustar permissões de home para 750 ou mais restritivas."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd | while read -r h; do [ -d \"$h\" ] && [ \"$(stat -Lc %a \"$h\")\" -le 750 ] || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "202, Dotfiles seguros, Baixa"
  info        : "Verificar permissões de dotfiles"
  solution    : "Ajustar permissões de dotfiles removendo escrita indevida."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( while read -r h; do [ -d \"$h\" ] || continue; find \"$h\" -maxdepth 1 -type f -name \".*\" -perm /022 2>/dev/null; done < <(awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd) | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "203, Arquivos trust legado, Alta"
  info        : "Verificar presença desses arquivos"
  solution    : "Remover ou proteger arquivos forward  netrc e rhosts conforme política."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( while read -r h; do [ -d \"$h\" ] || continue; for f in \"$h/.forward\" \"$h/.netrc\" \"$h/.rhosts\"; do [ -e \"$f\" ] && echo \"$f\"; done; done < <(awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd) | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "999, Verificacao de hardening aplicado v1.0.3 (log local)"
  info        : "Detecta a existencia do log de hardening para servidores."
  solution    : "Garantir que o processo de hardening escreva em /var/log/hitss-hardening.log com stamp padrao."
  reference   : "BASELINE"
  see_also    : "/var/log/hitss-hardening.log"
  cmd         : "sh -c 'if [ -f /var/log/hitss-hardening.log ]; then echo \"PASS | $(tail -n 1 /var/log/hitss-hardening.log)\"; else echo \"FAIL | sem_log\"; fi'"
  expect      : "^PASS"
</custom_item>

</check_type>

