  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '(find / -xdev -type d -perm -0002 ! -perm -1000 2>/dev/null | grep . && echo \"FAIL\" || echo \"PASS\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
