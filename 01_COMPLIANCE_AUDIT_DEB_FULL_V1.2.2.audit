<custom_item>
  type        : CMD_EXEC
  description : "131, pwquality configurado, Alta"
  info        : "Verificar parâmetros do pam_pwquality"
  solution    : "Configurar pam_pwquality conforme baseline."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( grep -Eq '\"'\"'pam_pwquality\\.so'\"'\"' /etc/pam.d/common-password 2>/dev/null && grep -Psiq '\"'\"'^\\s*minlen\\s*=\\s*(1[4-9]|[2-9][0-9]+)\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null && grep -Psiq '\"'\"'^\\s*minclass\\s*=\\s*[4-9]\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null && grep -Psiq '\"'\"'^\\s*maxrepeat\\s*=\\s*3\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null && grep -Psiq '\"'\"'^\\s*maxsequence\\s*=\\s*3\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null && grep -Psiq '\"'\"'^\\s*dictcheck\\s*=\\s*1\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

