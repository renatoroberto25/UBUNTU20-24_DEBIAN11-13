  cmd         : "bash -c '( stat -c %a /etc/ssh/sshd_config | grep -Eq '\"'\"'^(600|400)$'\"'\"' && [ \"$(stat -c %U:%G /etc/ssh)\" = \"root:root\" ] ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "110, Controle de acesso via Allow Deny, Média"
