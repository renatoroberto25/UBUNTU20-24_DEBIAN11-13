  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'service_active_any() { local svc; for svc in \"$@\"; do systemctl is-active --quiet \"$svc\" 2>/dev/null && return 0; done; return 1; }; ( service_active_any rsyslog systemd-journald && echo \"PASS\" || echo \"FAIL\" )'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "162, Journald persistente, Média"
