<custom_item>
  type        : CMD_EXEC
  description : "035, Nodev removíveis, Baixa"
  info        : "Verificar opções de montagem para mídias removíveis"
  solution    : "Ajustar opções nodev nosuid noexec para mídias removíveis no fstab."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'fstab_path_has_opts() { local path_re=\"$1\"; shift; local entry found opt entries; entries=\"$(grep -Ehv '\"'\"'^[[:space:]]*#|^[[:space:]]*$'\"'\"' /etc/fstab 2>/dev/null | awk -v p=\"$path_re\" '\"'\"'$2 ~ p {print $4}'\"'\"')\" || return 1; [ -n \"$entries\" ] || return 1; while read -r entry; do [ -n \"$entry\" ] || continue; found=1; for opt in \"$@\"; do grep -qw \"$opt\" <<< \"$entry\" || return 1; done; done <<< \"$entries\"; [ \"${found:-0}\" -eq 1 ]; }; (fstab_path_has_opts '\"'\"'^(/media|/run/media)'\"'\"' nodev nosuid noexec && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "036, Nodev partições críticas, Baixa"
  info        : "Verificar opções de montagem críticas"
  solution    : "Ajustar opções nodev nosuid para partições críticas."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'fstab_path_has_opts() { local path_re=\"$1\"; shift; local entry found opt entries; entries=\"$(grep -Ehv '\"'\"'^[[:space:]]*#|^[[:space:]]*$'\"'\"' /etc/fstab 2>/dev/null | awk -v p=\"$path_re\" '\"'\"'$2 ~ p {print $4}'\"'\"')\" || return 1; [ -n \"$entries\" ] || return 1; while read -r entry; do [ -n \"$entry\" ] || continue; found=1; for opt in \"$@\"; do grep -qw \"$opt\" <<< \"$entry\" || return 1; done; done <<< \"$entries\"; [ \"${found:-0}\" -eq 1 ]; }; (fstab_path_has_opts '\"'\"'^/(var|tmp|dev/shm|var/tmp|var/log|var/log/audit|home)$'\"'\"' nodev nosuid && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "037, Opcoes de montagem seguras em tmp, Alta"
  info        : "Checa se tmp possui opcoes nodev nosuid e noexec"
  solution    : "Aplicar opcoes seguras em tmp"
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'mount_has_opts() { local mountpoint=\"$1\"; shift; local opts opt; opts=\"$(findmnt -n -o OPTIONS --target \"$mountpoint\" 2>/dev/null)\" || return 1; for opt in \"$@\"; do grep -qw \"$opt\" <<< \"$opts\" || return 1; done; }; (mount_has_opts /tmp nodev nosuid noexec && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
