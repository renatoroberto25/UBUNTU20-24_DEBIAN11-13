  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '( [ -f /etc/passwd ] && stat -Lc '\"'\"'%a %u %g'\"'\"' /etc/passwd | awk '\"'\"'{m=$1+0; exit !($2==0 && $3==0 && m<=644 && int(m/10)%10<5 && m%10<5)}'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

