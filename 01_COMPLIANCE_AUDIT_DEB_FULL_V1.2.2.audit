<check_type:"Unix">

<custom_item>
  type        : CMD_EXEC
  description : "001, Bloqueio cramfs, Alta"
  info        : "Verificar se módulo cramfs está bloqueado"
  solution    : "Bloquear módulo cramfs persistentemente via modprobe.d e remover se carregado."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '(modinfo cramfs &>/dev/null && modprobe --showconfig | grep -Pq '\"'\"'\\b(install|blacklist)\\h+cramfs\\b'\"'\"' && ! lsmod | grep -q cramfs) || (! modinfo cramfs &>/dev/null) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

