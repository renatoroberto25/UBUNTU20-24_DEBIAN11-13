  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'pkg_installed() { dpkg-query -W -f='\"'\"'${Status}'\"'\"' \"$1\" 2>/dev/null | grep -q '\"'\"'install ok installed'\"'\"'; }; ( pkg_installed rsyslog && systemctl is-active rsyslog &>/dev/null ) && echo \"PASS\" || echo \"FAIL\"'"
