  solution    : "Configurar directivas Allow e Deny conforme politica"
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'sshd_effective_config() { if command -v sshd >/dev/null 2>&1; then sshd -T -C user=root,host=\"$(hostname 2>/dev/null || echo localhost)\",addr=127.0.0.1 2>/dev/null && return 0; fi; cat /etc/ssh/sshd_config /etc/ssh/sshd_config.d/*.conf 2>/dev/null; }; (sshd_effective_config | grep -Eiq '\"'\"'^(allowusers|allowgroups|denyusers|denygroups)[[:space:]]+'\"'\"' && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

