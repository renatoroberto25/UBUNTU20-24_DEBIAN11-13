<custom_item>
  type        : CMD_EXEC
  description : "089, Time sync único, Alta"
  info        : "Verificar serviços de tempo ativos"
  solution    : "Manter apenas um mecanismo de sincronização ativo."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c 'service_active_any() { local svc; for svc in \"$@\"; do systemctl is-active --quiet \"$svc\" 2>/dev/null && return 0; done; return 1; }; time_sync_active_count() { local count=0; service_active_any chrony chronyd && count=$((count + 1)); service_active_any ntp ntpd ntpsec && count=$((count + 1)); service_active_any systemd-timesyncd && count=$((count + 1)); echo \"$count\"; }; ([ \"$(time_sync_active_count)\" -eq 1 ] && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "090, Cron/at restritos, Alta"
  info        : "Verificar allow-list de usuários para cron e at"
  solution    : "Restringir o uso de cron e at por usuários locais."
  reference   : "BASELINE"
  see_also    : "BASELINE_UBUNTU20-24_DEBIAN11-13.csv"
  cmd         : "bash -c '(stat -Lc '\"'\"'%a %U %G'\"'\"' /etc/cron.allow 2>/dev/null | grep -Eq '\"'\"'^640 root (root|crontab)$'\"'\"' && [ ! -e /etc/cron.deny ] && { ! command -v at >/dev/null 2>&1 || { stat -Lc '\"'\"'%a %U %G'\"'\"' /etc/at.allow 2>/dev/null | grep -Eq '\"'\"'^640 root (root|daemon)$'\"'\"' && [ ! -e /etc/at.deny ]; }; } && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
