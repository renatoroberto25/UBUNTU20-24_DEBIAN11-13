  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'unlink|rename|rmdir|unlinkat|renameat'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
