  cmd         : "bash -c '( [ -f /etc/group- ] && stat -Lc \"%a %u %g\" /etc/group- | grep -Eq '\"'\"'^64[0-9] 0 0$'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "193, nologin fora de etc shells, Baixa"
  info        : "Garantir que nologin seja tratado de forma consistente"
  solution    : "Garantir que nologin seja tratado de forma consistente"
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -qE '\"'\"'^(\\/usr)?\\/sbin\\/nologin$'\"'\"' /etc/shells && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "194, Proteger opasswd, Alta"
  info        : "Protege o histórico de senhas locais contra leitura ou alteração indevida."
  solution    : "Proteger /etc/security/opasswd."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( [ -f /etc/security/opasswd ] && stat -Lc \"%a %u %g\" /etc/security/opasswd | grep -Eq '\"'\"'^600 0 0$'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "195, Arquivos órfãos, Baixa"
  info        : "Evita presença de arquivos locais sem proprietário válido."
  solution    : "Corrigir arquivos órfãos."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( find / -xdev \\( -nouser -o -nogroup \\) 2>/dev/null | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "196, Sticky world-writable, Alta"
  info        : "Impede exclusão indevida em diretórios compartilhados com escrita global."
  solution    : "Garantir sticky bit em diretórios world writable."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(find / -xdev -type d -perm -0002 ! -perm -1000 2>/dev/null | grep . && echo \"FAIL\" || echo \"PASS\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "197, Arquivos sem grupo, Baixa"
  info        : "Evita presença de arquivos locais sem owner ou grupo válido."
  solution    : "Corrigir arquivos sem owner ou grupo."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( find / -xdev \\( -nouser -o -nogroup \\) 2>/dev/null | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "198, SUID SGID revisados, Alta"
  info        : "Garante que SUID/SGID estejam configurados corretamente"
  solution    : "Ajustar permissões de arquivos executáveis"
  reference   : "Referência completa no Baseline HITSS."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( find / -xdev \\( -perm -4000 -o -perm -2000 \\) 2>/dev/null | grep -Ev '\"'\"'^(/usr/bin/sudo|/usr/bin/su|/bin/su|/usr/bin/passwd|/usr/bin/chage|/usr/bin/chsh|/usr/bin/chfn|/usr/bin/newgrp|/usr/bin/gpasswd|/usr/sbin/unix_chkpwd|/usr/sbin/pam_timestamp_check|/usr/bin/mount|/usr/bin/umount|/usr/bin/fusermount|/usr/bin/pkexec|/usr/bin/crontab|/usr/bin/ssh-agent|/usr/bin/ksu|/usr/libexec/openssh/ssh-keysign|/usr/bin/ping|/usr/bin/ping6|/usr/bin/traceroute|/usr/bin/traceroute6)$'\"'\"' | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "199, Home ausente, Baixa"
  info        : "Evita contas locais interativas sem diretório home válido."
  solution    : "Verificar usuários sem diretório home."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd | while read -r h; do [ -d \"$h\" ] || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "200, Ownership home, Alta"
  info        : "Garante que cada diretório home pertença ao usuário esperado."
  solution    : "Ajustar ownership dos diretórios home."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $1,$6}'\"'\"' /etc/passwd | while read -r u h; do [ -d \"$h\" ] && [ \"$(stat -Lc %U \"$h\")\" = \"$u\" ] || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "201, Permissões home, Alta"
  info        : "Evita diretórios home com permissões excessivas."
  solution    : "Ajustar permissões de home para 750."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd | while read -r h; do [ -d \"$h\" ] && [ \"$(stat -Lc %a \"$h\")\" -le 750 ] || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "202, Dotfiles seguros, Baixa"
  info        : "Evita exposição ou alteração indevida de arquivos ocultos em home."
  solution    : "Ajustar permissões de dotfiles."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( while read -r h; do [ -d \"$h\" ] || continue; find \"$h\" -maxdepth 1 -type f -name \".*\" -perm /022 2>/dev/null; done < <(awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd) | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "203, Arquivos trust legado, Alta"
  info        : "Evita mecanismos legados inseguros em diretórios home."
  solution    : "Remover arquivos .forward .netrc, .rhosts."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( while read -r h; do [ -d \"$h\" ] || continue; for f in \"$h/.forward\" \"$h/.netrc\" \"$h/.rhosts\"; do [ -e \"$f\" ] && echo \"$f\"; done; done < <(awk -F: '\"'\"'$3>=1000 && $1!=\"nobody\"{print $6}'\"'\"' /etc/passwd) | grep -q . ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "999, Verificacao de hardening aplicado v1.0.3 (log local)"
  info        : "Detecta a existencia do log de hardening para servidores."
  solution    : "Garantir que o processo de hardening escreva em /var/log/hitss-hardening.log com stamp padrao."
  reference   : "BASELINE"
  see_also    : "/var/log/hitss-hardening.log"
  cmd         : "sh -c 'if [ -f /var/log/hitss-hardening.log ]; then echo \"PASS | $(tail -n 1 /var/log/hitss-hardening.log)\"; else echo \"FAIL | sem_log\"; fi'"
  expect      : "^PASS"
</custom_item>



</check_type>