</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "139, Hash forte, Alta"
  info        : "Protege senhas armazenadas contra ataques offline."
  solution    : "Configurar algoritmo de hashing forte."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Eq '\"'\"'pam_unix\\.so.*(sha512|yescrypt)'\"'\"' /etc/pam.d/*auth && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "140, Histórico de senhas, Alta"
  info        : "Evita reuso imediato de credenciais antigas."
  solution    : "Configurar histórico de senha."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(grep -Eq '\"'\"'pam_pwhistory\\.so.*remember=([5-9]|[1-9][0-9]+)'\"'\"' /etc/pam.d/common-password 2>/dev/null) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "141, Bloqueio por tentativas invalidas, Alta"
  info        : "Configurar bloqueio por tentativas invalidas"
  solution    : "Configurar bloqueio por tentativas invalidas"
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Pi '\"'\"'^\\s*deny\\s*=\\s*([5-9]|[1-9][0-9]+)'\"'\"' /etc/security/faillock.conf && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "142, Tempo desbloqueio, Baixa"
  info        : "Define período de bloqueio adequado equilibrando segurança e usabilidade."
  solution    : "Configurar tempo de desbloqueio conforme política."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Pi '\"'\"'^\\s*unlock_time\\s*=\\s*(9[0-9]{2}|[1-9][0-9]{3,})\\b'\"'\"' /etc/security/faillock.conf && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "143, PASS_MAX_DAYS, Alta"
  info        : "Força renovação periódica de credenciais."
  solution    : "Configurar PASS_MAX_DAYS."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'val=$(awk '\"'\"'$1==\"PASS_MAX_DAYS\"{print $2; exit}'\"'\"' /etc/login.defs); [[ \"$val\" =~ ^[0-9]+$ ]] && [[ \"$val\" -le 365 ]] && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "144, PASS_MIN_DAYS, Baixa"
  info        : "Evita trocas sucessivas de senha para burlar histórico."
  solution    : "Configurar PASS_MIN_DAYS."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Eq '\"'\"'^\\s*PASS_MIN_DAYS\\s+[1-9][0-9]*'\"'\"' /etc/login.defs && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "145, PASS_WARN_AGE, Baixa"
  info        : "Notifica usuários antes da expiração evitando bloqueios inesperados."
  solution    : "Configurar PASS_WARN_AGE."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Eq '\"'\"'^\\s*PASS_WARN_AGE\\s+([7-9]|[1-9][0-9]+)'\"'\"' /etc/login.defs && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "146, INACTIVE ajustado, Alta"
  info        : "Define inativação automática de contas locais após expiração da senha."
  solution    : "Configurar parâmetro INACTIVE para contas locais."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'awk -F: '\"'\"'$2~/^\\$/ && ($7==\"\" || $7<30){exit 1}'\"'\"' /etc/shadow && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "147, Corrigir datas senha, Baixa"
  info        : "Evita contas locais ativas com data de última troca de senha no futuro."
  solution    : "Corrigir datas inconsistentes de troca de senha."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'awk -F: '\"'\"'$2~/^\\$/{if($3==\"\"||$3==0) exit 1} END{exit 0}'\"'\"' /etc/shadow && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "148, UID 0 exclusivo, Alta"
  info        : "Evita existência de contas privilegiadas adicionais com UID 0."
  solution    : "Garantir apenas root com UID 0."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'awk -F: '\"'\"'($3==0 && $1!=\"root\"){exit 1}'\"'\"' /etc/passwd && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "149, GID 0 exclusivo, Alta"
  info        : "Evita existência de grupos privilegiados adicionais com GID 0."
  solution    : "Garantir apenas grupo root com GID 0."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'awk -F: '\"'\"'($3==0 && $1!=\"root\"){exit 1}'\"'\"' /etc/group && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "150, Contas sistema bloqueadas, Alta"
  info        : "Evita login interativo em contas de sistema."
  solution    : "Bloquear contas de sistema com shell inválido."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'awk -F: '\"'\"'($3<1000 && $1!=\"root\" && $7 ~ /(bash|sh|zsh)$/){exit 1}'\"'\"' /etc/passwd && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "151, Shells válidos, Baixa"
  info        : "Evita exposição de shells não aprovados no sistema."
  solution    : "Remover shells inválidos de /etc/shells."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -qE '\"'\"'^(\\/usr)?\\/sbin\\/nologin$'\"'\"' /etc/shells && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "152, PATH root seguro, Alta"
  info        : "Evita uso de diretório corrente no PATH do root."
  solution    : "Ajustar PATH do root removendo diretórios inseguros."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(grep -Rqs '\"'\"'PATH=.*\\/usr/local/sbin.*\\/usr/sbin.*\\/sbin'\"'\"' /root/.profile /root/.bashrc /etc/profile /etc/profile.d 2>/dev/null) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "153, Umask restritiva, Alta"
  info        : "Define criação padrão de arquivos e diretórios com permissões mais restritivas."
  solution    : "Configurar umask restritiva padrão."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Rqs '\"'\"'umask 027'\"'\"' /etc/profile /etc/bash.bashrc /etc/profile.d 2>/dev/null && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "154, Timeout shell, Baixa"
  info        : "Encerra sessões inativas de shell reduzindo exposição por abandono de terminal."
  solution    : "Configurar timeout de shell."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Rqs '\"'\"'TMOUT=900'\"'\"' /etc/profile /etc/bash.bashrc /etc/profile.d 2>/dev/null && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "155, Sudo restrito, Alta"
  info        : "Centraliza privilégio administrativo em grupo autorizado."
  solution    : "Restringir administração privilegiada via sudo."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -RqsE '\"'\"'^%.*ALL=\\(ALL\\)'\"'\"' /etc/sudoers /etc/sudoers.d 2>/dev/null && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "156, Sudo tty, Alta"
  info        : "Associa execução privilegiada a terminal interativo."
  solution    : "Configurar sudo para uso de pseudo tty."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Rqs '\"'\"'use_pty'\"'\"' /etc/sudoers /etc/sudoers.d && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "157, Sudo logging, Alta"
  info        : "Registra uso de sudo em arquivo dedicado para auditoria."
  solution    : "Habilitar logging de sudo."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Rqs '\"'\"'logfile='\"'\"' /etc/sudoers /etc/sudoers.d && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "158, Reautenticacao nao desabilitada, Média"
  info        : "Garantir que reautenticacao nao esteja desabilitada"
  solution    : "Garantir que reautenticacao nao esteja desabilitada"
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Rqs '\"'\"'!authenticate'\"'\"' /etc/sudoers /etc/sudoers.d && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "159, Sudo timeout, Média"
  info        : "Limita tempo de reaproveitamento de credencial sudo."
  solution    : "Configurar timeout de autenticação sudo."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Rqs '\"'\"'timestamp_timeout=5'\"'\"' /etc/sudoers /etc/sudoers.d && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "160, su restrito, Alta"
  info        : "Restringe elevação via su a grupo autorizado."
  solution    : "Restringir uso de su a grupo autorizado."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -Eq '\"'\"'pam_wheel\\.so.*group=(sudo|wheel)'\"'\"' /etc/pam.d/su && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "161, Arquitetura logs, Baixa"
  info        : "Mantém mecanismo de logs habilitado conforme arquitetura aprovada."
  solution    : "Ajustar arquitetura de logs evitando duplicidade."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'service_active_any() { local svc; for svc in \"$@\"; do systemctl is-active --quiet \"$svc\" 2>/dev/null && return 0; done; return 1; }; ( service_active_any rsyslog systemd-journald && echo \"PASS\" || echo \"FAIL\" )'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "162, Journald persistente, Alta"
  info        : "Mantém persistência de logs locais no journald."
  solution    : "Configurar journald com persistência."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -q '\"'\"'^Storage=persistent'\"'\"' /etc/systemd/journald.conf && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "163, rsyslog ativo, Baixa"
  info        : "Garante serviço rsyslog habilitado para coleta e encaminhamento de logs."
  solution    : "Instalar e ativar rsyslog."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'pkg_installed() { dpkg-query -W -f='\"'\"'${Status}'\"'\"' \"$1\" 2>/dev/null | grep -q '\"'\"'install ok installed'\"'\"'; }; ( pkg_installed rsyslog && systemctl is-active rsyslog &>/dev/null ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "164, Rotação logs, Alta"
  info        : "Mantém retenção e renovação periódica dos logs locais."
  solution    : "Configurar rotação de logs."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( grep -Eq '\"'\"'rsyslog'\"'\"' /etc/logrotate.d/* 2>/dev/null ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "165, auditd instalado, Alta"
  info        : "Garante serviço de auditoria habilitado no sistema."
  solution    : "Instalar e habilitar auditd."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'pkg_installed() { dpkg-query -W -f='\"'\"'${Status}'\"'\"' \"$1\" 2>/dev/null | grep -q '\"'\"'install ok installed'\"'\"'; }; ( ( pkg_installed audit || pkg_installed auditd ) && systemctl is-active auditd &>/dev/null ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "166, auditd no boot, Alta"
  info        : "Garante inicialização do auditd em fase adequada do boot."
  solution    : "Garantir auditd antes de serviços críticos."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grep -q '\"'\"'audit=1'\"'\"' /proc/cmdline && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "167, Tamanho máximo audit, Alta"
  info        : "Define tamanho máximo do arquivo de auditoria antes de ação rotativa."
  solution    : "Configurar max_log_file."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( grep -Eq '\"'\"'^\\s*max_log_file\\s*=\\s*[1-9]'\"'\"' /etc/audit/auditd.conf ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "168, Logs de auditoria nao excluidos automaticamente, Alta"
  info        : "Evitar exclusao automatica de logs de auditoria"
  solution    : "Evitar exclusao automatica de logs de auditoria"
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( grep -Eq '\"'\"'^\\s*max_log_file_action\\s*=\\s*(keep_logs|rotate)'\"'\"' /etc/audit/auditd.conf ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "169, Auditoria data/hora, Alta"
  info        : "Registra alterações relevantes de data e hora no sistema."
  solution    : "Auditar alterações de data e hora."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'adjtimex|settimeofday|clock_settime'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "170, Auditoria contas, Alta"
  info        : "Registra alterações em arquivos críticos de contas e grupos."
  solution    : "Auditar alterações de contas e grupos."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'/etc/(passwd|shadow|group|gshadow)'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "171, Auditoria rede, Média"
  info        : "Registra alterações em arquivos críticos de configuração de rede."
  solution    : "Auditar alterações de rede."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'sethostname|setdomainname|/etc/hosts|/etc/hostname'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "173, Auditoria login, Alta"
  info        : "Registra eventos de autenticação e sessão."
  solution    : "Auditar eventos de login."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'/var/log/faillog|/var/log/lastlog|/var/run/utmp'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "174, Auditoria DAC, Baixa"
  info        : "Registra mudanças relevantes de permissões e propriedades."
  solution    : "Auditar mudanças de permissões."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'chmod|chown|fchmod|fchown'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "175, Auditoria acesso negado, Alta"
  info        : "Registra negações de acesso relevantes para investigação."
  solution    : "Auditar EACCES e EPERM."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'EACCES|EPERM'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "176, Auditoria exec privilegiado, Alta"
  info        : "Registra execuções de processos relevantes para rastreabilidade."
  solution    : "Auditar execve."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( find / -xdev -perm -4000 -type f 2>/dev/null | while read -r f; do auditctl -l 2>/dev/null | grep -q \"$f\" || exit 1; done ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "177, Auditoria mount, Baixa"
  info        : "Registra operações de montagem e desmontagem de sistemas de arquivos."
  solution    : "Auditar mount."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( auditctl -l 2>/dev/null | grep -Eq '\"'\"'mount|umount'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

