  cmd         : "bash -c '(sysctl -n net.ipv4.ip_forward 2>/dev/null | grep -q '\"'\"'^0$'\"'\"' && sysctl -n net.ipv6.conf.all.forwarding 2>/dev/null | grep -q '\"'\"'^0$'\"'\"' && echo \"PASS\" || echo \"FAIL\")'"
