  cmd         : "bash -c '( [ -f /etc/shadow- ] && stat -Lc \"%a %u %g\" /etc/shadow- | grep -Eq '\"'\"'^0+ 0 0$'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
