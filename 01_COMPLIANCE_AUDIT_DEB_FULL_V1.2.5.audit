  cmd         : "bash -c '(sysctl -n net.ipv4.conf.all.accept_redirects 2>/dev/null | grep -q '\"'\"'^0$'\"'\"' && sysctl -n net.ipv4.conf.all.secure_redirects 2>/dev/null | grep -q '\"'\"'^0$'\"'\"' && echo \"PASS\" || echo \"FAIL\")'"
