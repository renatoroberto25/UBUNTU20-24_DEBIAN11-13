<check_type:"Unix">

<custom_item>
  type        : CMD_EXEC
  description : "001, Bloqueio cramfs, Alta"
  info        : "Reduz superfície de ataque removendo suporte a filesystem legado raramente necessário"
  solution    : "Bloquear módulo via modprobe.d e remover se carregado"
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://man7.org/linux/man-pages/man8/modprobe.8.html"
  cmd         : "bash -c '(modinfo cramfs &>/dev/null && modprobe --showconfig | grep -Pq '\"'\"'\\b(install|blacklist)\\h+cramfs\\b'\"'\"' && ! lsmod | grep -q cramfs) || (! modinfo cramfs &>/dev/null) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "002, Bloqueio squashfs, Alta"
  info        : "Reduz superfície de ataque associada a arquivos comprimidos montados indevidamente"
  solution    : "Bloquear módulo via modprobe.d e remover se carregado"
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://man7.org/linux/man-pages/man8/modprobe.8.html"
  cmd         : "bash -c '(modinfo squashfs &>/dev/null && modprobe --showconfig | grep -Pq '\"'\"'\\b(install|blacklist)\\h+squashfs\\b'\"'\"' && ! lsmod | grep -q squashfs) || (! modinfo squashfs &>/dev/null) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
