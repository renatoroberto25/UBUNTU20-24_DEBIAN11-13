<custom_item>
  type        : CMD_EXEC
  description : "086, Polkit seguro, Alta"
  info        : "Evita regras permissivas no PolicyKit fora do baseline aprovado."
  solution    : "Configurar polkit conforme baseline aprovado."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( grep -Ehv '\"'\"'^[[:space:]]*(//|#)'\"'\"' /etc/polkit-1/rules.d/*.rules 2>/dev/null | grep -Eq '\"'\"'polkit\\.Result\\.YES|[^[:alnum:]_]allow[^[:alnum:]_]'\"'\"' ) && echo \"FAIL\" || echo \"PASS\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "087, gpgcheck ativo, Baixa"
  info        : "Garante validação de assinatura de pacotes em todos os repositórios."
  solution    : "Habilitar gpgcheck em todos os repositórios."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(find /etc/apt/sources.list /etc/apt/sources.list.d -type f -print0 2>/dev/null | xargs -0r grep -Ehv '\"'\"'^[[:space:]]*#'\"'\"' 2>/dev/null | grep -Eq '\"'\"'^[[:space:]]*deb[[:space:]]'\"'\"' && ! apt-config dump 2>/dev/null | grep -Eq '\"'\"'Acquire::AllowInsecureRepositories \"true\"|APT::Get::AllowUnauthenticated \"true\"'\"'\"' && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
