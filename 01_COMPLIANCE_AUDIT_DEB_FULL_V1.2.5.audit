  reference   : "Referência completa no Baseline HITSS."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grub_cfg_path() { if [ -f /boot/grub/grub.cfg ]; then echo /boot/grub/grub.cfg; elif [ -f /boot/grub2/grub.cfg ]; then echo /boot/grub2/grub.cfg; else echo \"\"; fi; }; GRUBCFG=\"$(grub_cfg_path)\"; if [ -n \"$GRUBCFG\" ]; then (grep -q '\"'\"'password_pbkdf2'\"'\"' \"$GRUBCFG\" 2>/dev/null && echo \"PASS\" || echo \"FAIL\"); else echo \"FAIL\"; fi'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "050, Permissoes seguras no arquivo do bootloader, Média"
  info        : "Garante que o arquivo do bootloader tenha permissões seguras configuradas"
