  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(apt list --upgradable 2>/dev/null | grep -Eiq '\"'\"'security|ubuntu[[:alnum:].-]+-security|debian-security'\"'\"' && echo \"FAIL\" || echo \"PASS\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "089, Time sync único, Alta"
  info        : "Evita conflito entre mecanismos simultâneos de sincronização de tempo."
  solution    : "Manter apenas um mecanismo de sincronização ativo."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'service_active_any() { local svc; for svc in \"$@\"; do systemctl is-active --quiet \"$svc\" 2>/dev/null && return 0; done; return 1; }; time_sync_active_count() { local count=0; service_active_any chrony chronyd && count=$((count + 1)); service_active_any ntp ntpd ntpsec && count=$((count + 1)); service_active_any systemd-timesyncd && count=$((count + 1)); echo \"$count\"; }; ([ \"$(time_sync_active_count)\" -eq 1 ] && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "090, Cron/at restritos, Alta"
  info        : "Restringir cron e at a usuários autorizados."
  solution    : "Restringir acesso conforme política de usuários autorizados."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(stat -Lc '\"'\"'%a %U %G'\"'\"' /etc/cron.allow 2>/dev/null | grep -Eq '\"'\"'^640 root (root|crontab)$'\"'\"' && echo \"PASS\" || echo \"FAIL\")'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
