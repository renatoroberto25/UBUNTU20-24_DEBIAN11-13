  cmd         : "bash -c '( [ -f /etc/gshadow- ] && stat -Lc \"%a %u %g\" /etc/gshadow- | grep -Eq '\"'\"'^(600|60[0-9]|[0-5][0-9]{2}) 0 0$'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

