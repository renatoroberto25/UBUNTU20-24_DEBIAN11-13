<custom_item>
  type        : CMD_EXEC
  description : "108, TLS mínimo 1.2+, Alta"
  info        : "Exigir uso de TLS 1.2 ou superior para serviços e comunicações."
  solution    : "Exigir uso de TLS 1.2 ou superior para serviços e comunicações."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '(grep -REiq '\"'\"'MinProtocol[[:space:]]*=[[:space:]]*TLSv1\\.[23]|TLS.MinProtocol[[:space:]]*=[[:space:]]*TLSv1\\.[23]'\"'\"' /etc/ssl/openssl.cnf /etc/ssl/openssl.cnf.d /etc/ssl/openssl.cnf.d/* 2>/dev/null) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "109, Permissões SSH seguras, Baixa"
  info        : "Protege arquivos e diretório do serviço SSH contra alteração indevida."
  solution    : "Ajustar permissões de sshd_config e diretório /etc/ssh."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( stat -c %a /etc/ssh/sshd_config | grep -Eq '\"'\"'^(600|400)$'\"'\"' && [ \"$(stat -c %U:%G /etc/ssh)\" = \"root:root\" ] ) && echo \"PASS\" || echo \"FAIL\"'"
