  reference   : "Referência completa no Baseline HITSS."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c 'grub_cfg_path() { if [ -f /boot/grub/grub.cfg ]; then echo /boot/grub/grub.cfg; elif [ -f /boot/grub2/grub.cfg ]; then echo /boot/grub2/grub.cfg; else echo \"\"; fi; }; GRUBCFG=\"$(grub_cfg_path)\"; if [ -n \"$GRUBCFG\" ]; then (stat -Lc '\"'\"'%a %U %G'\"'\"' \"$GRUBCFG\" 2>/dev/null | grep -Eq '\"'\"'^(400|600) root root$'\"'\"' && echo \"PASS\" || echo \"FAIL\"); else echo \"FAIL\"; fi'"
