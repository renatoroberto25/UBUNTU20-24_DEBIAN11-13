  cmd         : "bash -c '( [ -f /etc/group ] && stat -Lc \"%a %u %g\" /etc/group | grep -Eq '\"'\"'^64[0-9] 0 0$'\"'\"' ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
