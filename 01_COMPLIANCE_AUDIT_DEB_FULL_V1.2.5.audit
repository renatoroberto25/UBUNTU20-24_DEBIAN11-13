</custom_item>

<custom_item>
  type        : CMD_EXEC
  description : "131, pwquality configurado, Alta"
  info        : "Define critérios técnicos mínimos para criação de senhas seguras."
  solution    : "Configurar pam_pwquality conforme baseline."
  reference   : "Referência completa no Baseline HITSS para Debian."
  see_also    : "https://www.debian.org/doc/manuals/securing-debian-manual/"
  cmd         : "bash -c '( grep -Eq '\"'\"'pam_pwquality\\.so'\"'\"' /etc/pam.d/common-password 2>/dev/null && grep -Psiq '\"'\"'^\\s*minlen\\s*=\\s*(1[4-9]|[2-9][0-9]+)\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null && grep -Psiq '\"'\"'^\\s*minclass\\s*=\\s*[4-9]\\b'\"'\"' /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf 2>/dev/null ) && echo \"PASS\" || echo \"FAIL\"'"
  expect      : "(?i)^\s*pass\s*$"
</custom_item>

